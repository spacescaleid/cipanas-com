// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum Role {
  VISITOR
  CONTRIBUTOR
  ADMIN
  SUPER_ADMIN
}

enum ArticleStatus {
  DRAFT
  PENDING
  REVISION
  PUBLISHED
  REJECTED
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}

enum AdPosition {
  HEADER
  SIDEBAR
  INLINE
  FOOTER
}

enum AdOrderStatus {
  PENDING_PAYMENT
  AWAITING_CREATIVE
  PENDING_REVIEW
  ACTIVE
  EXPIRED
  REJECTED
}

// ═══════════════════════════════════════════════════════════════
// USER & AUTH (NextAuth Prisma Adapter)
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  role          Role      @default(VISITOR)
  image         String?
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  // Relations
  articles          Article[]
  activityLogs      ActivityLog[]
  accounts          Account[]
  sessions          Session[]
  confirmedAdOrders AdOrder[] @relation("PaymentConfirmedBy")
  reviewedAdOrders  AdOrder[] @relation("ReviewedBy")

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
// CONTENT
// ═══════════════════════════════════════════════════════════════

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  articles Article[]

  @@map("categories")
}

model Article {
  id           String        @id @default(cuid())
  authorId     String
  title        String
  slug         String        @unique
  content      String        @db.Text
  coverImage   String?
  categoryId   String
  status       ArticleStatus @default(DRAFT)
  revisionNote String?       @db.Text
  viewCount    Int           @default(0)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  comments Comment[]

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt])
  @@map("articles")
}

// TODO: Belum diimplementasi di UI. Model ini ada di skema untuk
// menampung struktur data komentar di masa depan, tapi belum ada
// route atau komponen yang membaca/menulis ke tabel ini.
model Comment {
  id        String        @id @default(cuid())
  articleId String
  name      String
  content   String        @db.Text
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("comments")
}

// ═══════════════════════════════════════════════════════════════
// ADS SYSTEM (WA Manual Flow)
// ═══════════════════════════════════════════════════════════════

model AdSlot {
  id          String     @id @default(cuid())
  position    AdPosition
  size        String
  label       String?
  pricePerDay Decimal    @db.Decimal(12, 2)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  orders AdOrder[]

  @@map("ad_slots")
}

model AdOrder {
  id             String        @id @default(cuid())
  orderCode      String?       @unique
  advertiserName String?
  businessName   String?
  whatsappNumber String?
  email          String?
  slotId         String
  status         AdOrderStatus @default(PENDING_PAYMENT)
  startDate      DateTime
  endDate        DateTime
  totalPrice     Decimal       @db.Decimal(12, 2)

  // Materi iklan
  imageUrl  String?
  mediaUrl  String?
  targetUrl String?
  altText   String?

  // Token upload
  uploadToken          String?   @unique
  uploadTokenExpiresAt DateTime?

  // Verifikasi pembayaran
  paymentConfirmedAt   DateTime?
  paymentConfirmedById String?
  paymentConfirmedBy   User?     @relation("PaymentConfirmedBy", fields: [paymentConfirmedById], references: [id], onDelete: SetNull)

  // Review materi
  creativeSubmittedAt DateTime?
  reviewedAt          DateTime?
  reviewedById        String?
  reviewedBy          User?     @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason     String?   @db.Text

  // Statistik
  impressionCount Int @default(0)
  clickCount      Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  slot     AdSlot    @relation(fields: [slotId], references: [id])
  payments Payment[]

  @@index([status])
  @@index([slotId])
  @@index([orderCode])
  @@index([uploadToken])
  @@map("ad_orders")
}

model Payment {
  id            String   @id @default(cuid())
  adOrderId     String
  amount        Decimal  @db.Decimal(12, 2)
  method        String
  gatewayStatus String
  paymentRef    String?
  createdAt     DateTime @default(now())

  adOrder AdOrder @relation(fields: [adOrderId], references: [id], onDelete: Cascade)

  @@index([adOrderId])
  @@map("payments")
}

// ═══════════════════════════════════════════════════════════════
// ACTIVITY LOG
// ═══════════════════════════════════════════════════════════════

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}