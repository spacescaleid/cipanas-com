  await prisma.adOrder.update({
    where: { id: adOrderId },
    data: { impressionCount: { increment: 1 } },
  });
}

export async function incrementAdClick(adOrderId: string) {
  await prisma.adOrder.update({
    where: { id: adOrderId },
    data: { clickCount: { increment: 1 } },
  });
}